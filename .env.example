# ── DATABASE ─────────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql://user:pass@localhost:5432/nj_realtor
REDIS_URL=redis://localhost:6379

# ── MLS / IDX ────────────────────────────────────────────────────────────────
# RESO Web API (most NJ MLS boards use this standard)
MLS_BASE_URL=https://api.yournjmls.com/reso/odata
MLS_CLIENT_ID=your_client_id
MLS_CLIENT_SECRET=your_client_secret
MLS_TOKEN_URL=https://api.yournjmls.com/oauth/token

# Garden State MLS (GSMLS) — largest NJ MLS
GSMLS_API_KEY=your_gsmls_key
GSMLS_BASE_URL=https://data.gsmls.com/reso/odata

# Bright MLS (covers South Jersey / Delaware Valley)
BRIGHT_MLS_KEY=your_bright_key
BRIGHT_MLS_URL=https://api.brightmls.com/v2

# ── CRAWL4AI ─────────────────────────────────────────────────────────────────
# Self-hosted Crawl4AI service URL (Docker container)
CRAWL4AI_URL=http://localhost:11235
CRAWL4AI_API_KEY=your_crawl4ai_key

# ── AI PROVIDERS ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key        # for embeddings (text-embedding-3-large)

# ── NJ PUBLIC RECORDS ────────────────────────────────────────────────────────
# NJ Division of Taxation — Property Assessment data (free, public)
NJ_TAX_API=https://www.njactb.org
# Atlantic, Bergen, Burlington, Camden, Cape May, Cumberland,
# Essex, Gloucester, Hudson, Hunterdon, Mercer, Middlesex,
# Monmouth, Morris, Ocean, Passaic, Salem, Somerset, Sussex, Union, Warren

# NJ Courts (lien search, lis pendens)
NJ_COURTS_URL=https://portal.njcourts.gov/webe4/ExternalPJL.jsp

# NJ DEP Environmental data (flood zones, brownfields, contamination)
NJ_DEP_URL=https://gisdata-njdep.opendata.arcgis.com
NJ_FLOOD_ZONE_WMS=https://njfloodmapper.org/api

# NJ OpenData (permits, zoning, assessments)
NJ_OPENDATA_URL=https://data.nj.gov/resource

# ── DEMOGRAPHICS / NEIGHBORHOOD ──────────────────────────────────────────────
# US Census Bureau (ACS 5-year estimates)
CENSUS_API_KEY=your_census_key
CENSUS_BASE_URL=https://api.census.gov/data

# Walk Score API
WALKSCORE_API_KEY=your_walkscore_key
WALKSCORE_URL=https://api.walkscore.com/score

# GreatSchools API
GREATSCHOOLS_API_KEY=your_greatschools_key
GREATSCHOOLS_URL=https://gs-api.greatschools.net

# Crime data — SpotCrime / CrimeMapping
SPOTCRIME_API_KEY=your_spotcrime_key

# ── TRANSIT / COMMUTE ────────────────────────────────────────────────────────
# NJ Transit GTFS + real-time feeds (free, public)
NJ_TRANSIT_GTFS=https://www.njtransit.com/mb_pdf.shtml
NJ_TRANSIT_RT=https://api.njtransit.com/NJTVision.asmx
NJ_TRANSIT_API_KEY=your_njtransit_key

# Google Maps Platform (commute time, transit routing)
GOOGLE_MAPS_API_KEY=your_google_maps_key

# ── MARKET / FINANCIAL DATA ──────────────────────────────────────────────────
# FRED (Federal Reserve Economic Data) — mortgage rates, housing indexes
FRED_API_KEY=your_fred_key
FRED_URL=https://api.stlouisfed.org/fred

# ATTOM Data (deed, mortgage, foreclosure, AVM)
ATTOM_API_KEY=your_attom_key
ATTOM_URL=https://api.gateway.attomdata.com

# CoreLogic (property intelligence, flood/fire risk)
CORELOGIC_API_KEY=your_corelogic_key

# Redfin Data Center (public, no key needed)
REDFIN_DATA_URL=https://www.redfin.com/stingray/api/gis-csv

# HouseCanary (AVM + market analytics)
HOUSECANARY_API_KEY=your_housecanary_key
HOUSECANARY_URL=https://api.housecanary.com/v2

# ── MORTGAGE / RATES ─────────────────────────────────────────────────────────
# Freddie Mac PMMS (weekly rate survey, free)
FREDDIE_PMMS_URL=http://www.freddiemac.com/pmms/docs/historicalweeklydata.xls

# Optimal Blue (real-time mortgage rate data)
OPTIMAL_BLUE_KEY=your_ob_key

# ── PROPERTY PHOTOS / VIRTUAL TOURS ─────────────────────────────────────────
# Matterport (3D virtual tours)
MATTERPORT_API_KEY=your_matterport_key

# CloudFlare Images (CDN for scraped/uploaded photos)
CF_IMAGES_TOKEN=your_cf_token
CF_ACCOUNT_ID=your_cf_account

# ── COMMUNICATIONS ───────────────────────────────────────────────────────────
# Twilio (SMS showing confirmations, client alerts)
TWILIO_SID=your_twilio_sid
TWILIO_AUTH=your_twilio_auth
TWILIO_FROM=+17325551234

# SendGrid (email CMAs, market digests)
SENDGRID_API_KEY=your_sendgrid_key
REALTOR_EMAIL=agent@youroffice.com

# ── CALENDAR ─────────────────────────────────────────────────────────────────
GOOGLE_CALENDAR_CLIENT_ID=your_gcal_client
GOOGLE_CALENDAR_CLIENT_SECRET=your_gcal_secret
GOOGLE_CALENDAR_REFRESH_TOKEN=your_gcal_refresh

# ── SERVER ───────────────────────────────────────────────────────────────────
MCP_PORT=3000
NODE_ENV=development
LOG_LEVEL=info
